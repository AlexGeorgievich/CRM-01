# APP
APP_NAME=CRM-MiniSystem
APP_ENV=development
APP_DEBUG=True
APP_PORT=8001
FRONTEND_PORT=3002
NEXT_PUBLIC_USE_MOCKS=true
SECRET_KEY=change-this-secret-key-before-production-0001

# DATABASE (PostgreSQL)
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_db
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@postgres:5432/crm_db
SQL_ECHO=False

# REDIS
REDIS_URL=redis://redis:6379/0

# AUTH
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-admin-password
INITIAL_ADMIN_FULL_NAME=CRM Administrator
INITIAL_ADMIN_EMAIL=admin@example.local
